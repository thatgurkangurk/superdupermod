{
  "schemaVersion": 1,
  "id": "superdupermod",
  "version": "@version@",

  "name": "Super Duper Mod",
  "description": "a super duper amazing mod made by gurkan",
  "authors": ["Gurkan"],
  "contact": {},
  "icon": "./assets/icon.png",

  "license": "MPL-2.0",

  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "me.gurkz.superdupermod.SuperDuperMod"
      }
    ],
    "client": [
      {
        "adapter": "kotlin",
        "value": "me.gurkz.superdupermod.client.SuperDuperClient"
      }
    ],
    "fabric-datagen": [
      {
        "adapter": "kotlin",
        "value": "me.gurkz.superdupermod.client.SuperDuperDataGenerator"
      }
    ]
  },

  "mixins": [
    "superdupermod.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=@loader_version@",
    "fabric": "*",
    "minecraft": [
      "@supported_versions@"
    ],
    "fabric-language-kotlin": ">=@fabric_kotlin_version@",
    "fabric-permissions-api-v0": "*",
    "silk-core": ">=@silk_version@",
    "silk-commands": ">=@silk_version@"
  }
}